<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RootNamespace>BodyTracker</RootNamespace>
    <AssemblyName>BodyTracker</AssemblyName>
  </PropertyGroup>

  <!-- OpenCvSharp: wraps OpenCV for camera capture and image processing -->
  <ItemGroup>
    <PackageReference Include="OpenCvSharp4"                    Version="4.9.0.20240103" />
    <PackageReference Include="OpenCvSharp4.runtime.win"        Version="4.9.0.20240103" Condition="$([MSBuild]::IsOSPlatform('Windows'))" />
    <PackageReference Include="OpenCvSharp4.runtime.linux"      Version="4.9.0.20240103" Condition="$([MSBuild]::IsOSPlatform('Linux'))" />
    <PackageReference Include="OpenCvSharp4.runtime.osx"        Version="4.9.0.20240103" Condition="$([MSBuild]::IsOSPlatform('OSX'))" />
    <!-- ONNX Runtime: runs the neural-network pose model -->
    <PackageReference Include="Microsoft.ML.OnnxRuntime"        Version="1.17.3" />
  </ItemGroup>

</Project>
